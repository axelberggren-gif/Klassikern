# =============================================================================
# Klassikern Webapp - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your Supabase project credentials.
#
# You can find these values in your Supabase project dashboard:
#   Settings > API > Project URL and anon/public key
# =============================================================================

# Supabase project URL (e.g. https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase anonymous (public) key - safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key - NEVER expose this in the browser!
# Only used server-side for admin operations (seeding data, awarding badges, etc.)
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# Strava API (for Strava integration)
# =============================================================================
# Create an app at https://www.strava.com/settings/api

STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
STRAVA_VERIFY_TOKEN=your_random_webhook_verify_token

# Site URL (used for redirects after Strava OAuth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
